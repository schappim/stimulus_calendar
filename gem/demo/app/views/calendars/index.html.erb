<h1>Events (<%= @events.size %>)</h1>

<p>
  Range: <strong><%= @start.iso8601 %></strong> &rarr;
         <strong><%= @end.iso8601 %></strong>
</p>

<%# Renders the stimulus_calendar JS calendar driven by the EventCalendar
    server-side schema, with live multi-user sync via Turbo Streams. %>
<%= render partial: "stimulus_calendar_rails/calendars/calendar",
           locals: {
             calendar: EventCalendar.new(user: nil),
             events: @events,
             view: "timeGridWeek",
             plugins: %w[DayGrid TimeGrid Interaction],
             height: "600px",
           } %>

<%# Fallback table so the integration test sees a deterministic event list. %>
<table>
  <thead>
    <tr>
      <th>Title</th><th>Starts</th><th>Ends</th><th>Resource</th><th>All-day</th>
    </tr>
  </thead>
  <tbody>
    <% @events.each do |event| %>
      <tr id="event-<%= event.id %>">
        <td><%= event.title %></td>
        <td><%= event.starts_at.iso8601 %></td>
        <td><%= event.ends_at.iso8601 %></td>
        <td><%= event.resource&.title %></td>
        <td><%= event.all_day ? "Yes" : "No" %></td>
      </tr>
    <% end %>
  </tbody>
</table>

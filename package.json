{
  "name": "@ninjaai/stimulus_calendar",
  "version": "0.0.0",
  "description": "Full-sized drag & drop event calendar for Stimulus.js (Hotwire) — month, week, day, list, resource and timeline views; live multi-user sync over Turbo Streams. A 100% Stimulus port of vkurko/calendar.",
  "type": "module",
  "license": "MIT",
  "author": "Marcus Schappi",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/schappim/stimulus_calendar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schappim/stimulus_calendar.git"
  },
  "bugs": {
    "url": "https://github.com/schappim/stimulus_calendar/issues"
  },
  "keywords": [
    "stimulus",
    "hotwire",
    "turbo",
    "calendar",
    "event-calendar",
    "scheduler",
    "resource-timeline",
    "drag-and-drop"
  ],
  "main": "dist/stimulus_calendar.esm.js",
  "module": "dist/stimulus_calendar.esm.js",
  "unpkg": "dist/stimulus_calendar.js",
  "jsdelivr": "dist/stimulus_calendar.js",
  "exports": {
    ".": {
      "import": "./dist/stimulus_calendar.esm.js",
      "default": "./dist/stimulus_calendar.esm.js"
    },
    "./style.css": "./dist/stimulus_calendar.css",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "FORMAT=iife vite build --config vite.lib.config.js && FORMAT=es vite build --config vite.lib.config.js",
    "build:lib:iife": "FORMAT=iife vite build --config vite.lib.config.js",
    "build:lib:esm": "FORMAT=es vite build --config vite.lib.config.js",
    "build:lib:watch": "FORMAT=iife vite build --config vite.lib.config.js --watch",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build:lib && npm test"
  },
  "peerDependencies": {
    "@hotwired/stimulus": "^3.2.2"
  },
  "devDependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@playwright/test": "^1.60.0",
    "happy-dom": "^20.9.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
